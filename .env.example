# OpenAI
OPENAI_API_KEY=sk-...

# LangSmith Observability
LANGCHAIN_TRACING_V2=true
LANGCHAIN_API_KEY=ls__...
LANGCHAIN_PROJECT=research-assistant

# Serper Web Search (optional — falls back to DuckDuckGo)
SERPER_API_KEY=

# Redis
REDIS_URL=redis://localhost:6379

# Application
APP_ENV=development
LOG_LEVEL=INFO
MAX_RETRIES=2
CONFIDENCE_THRESHOLD_PASS=0.7
CONFIDENCE_THRESHOLD_CLARIFY=0.5
CONTEXT_WINDOW_LIMIT=8000
TOP_K_RETRIEVAL=5
TOP_K_MEMORY=3

# Model settings
LLM_MODEL=gpt-4o
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
RERANKER_MODEL=cross-encoder/ms-marco-MiniLM-L-6-v2

# Paths
CORPUS_PATH=data/corpus
FAISS_INDEX_PATH=data/faiss_index
FAISS_MEMORY_PATH=data/faiss_memory
BM25_INDEX_PATH=data/bm25_index.pkl
PROMPTS_DIR=prompts/v1
